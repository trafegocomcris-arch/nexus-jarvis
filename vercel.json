{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Permissions-Policy", "value": "microphone=*" }
      ]
    }
  ]
}
